models/players/scourge/body
{
	cull	twosided
    {
        map models/players/scourge/body
        rgbGen lightingDiffuse
        //alphaFunc GE128
    }
    {
        map models/players/scourge/body
        blendFunc GL_SRC_ALPHA GL_ONE
        alphaGen lightingSpecular
	detail
    }
    {
        map models/players/scourge/body_glow
        blendFunc GL_ONE GL_ONE
        detail
        rgbGen identity
    }
}

