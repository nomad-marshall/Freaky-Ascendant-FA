
//Crosshair
models/players/crosshair/antenna
{
	cull	twosided
    {
        map models/players/crosshair/antenna
        rgbGen lightingDiffuse
        //alphaFunc GE128
    }
    {
        map models/players/crosshair/antenna
        blendFunc GL_SRC_ALPHA GL_ONE
        alphaGen lightingSpecular
	detail
    }
}

